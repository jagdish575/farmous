# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Render: https://your-app.onrender.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com

# Neon PostgreSQL (recommended: use pooler host for Django)
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-round-fire-ap7bwxg3-pooler.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require

# Or set individual Neon vars (used when DATABASE_URL is empty):
NEON_DB_HOST=ep-round-fire-ap7bwxg3-pooler.c-7.us-east-1.aws.neon.tech
NEON_DB_DIRECT_HOST=ep-round-fire-ap7bwxg3.c-7.us-east-1.aws.neon.tech
NEON_DB_NAME=neondb
NEON_DB_USER=neondb_owner
NEON_DB_PASSWORD=YOUR_PASSWORD
NEON_DB_PORT=5432
NEON_DB_SSLMODE=require

# Kaggle (required for fetch_kaggle_data on server)
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-api-key

# Twilio Verify (optional — OTP login is commented out for now)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=your-twilio-verify-service-sid

# Razorpay payments
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
